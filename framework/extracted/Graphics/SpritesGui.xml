<?xml version="1.0" encoding="utf-8" ?>
<Sprites>
  <maggy_heartgem0 path="collectables/Maggy/heartgem/0/" start="idle">
    <Center />
    <Loop id="idle" path="spin" frames="0" />
    <Loop id="spin" path="spin" frames="0*10,1-10" delay="0.08"/>
    <Loop id="fastspin" path="spin"  frames="1-10" delay="0.08"/>
  </maggy_heartgem0>

  <maggy_heartgem1 path="collectables/Maggy/heartgem/1/" start="idle">
    <Center />
    <Loop id="idle" path="spin" frames="0" />
    <Loop id="spin" path="spin" frames="0*10,1-10" delay="0.08"/>
    <Loop id="fastspin" path="spin" frames="1-10" delay="0.08"/>
  </maggy_heartgem1>
	
  <maggy_heartgem2 path="collectables/Maggy/heartgem/2/" start="idle">
    <Center />
    <Loop id="idle" path="spin" frames="0" />
    <Loop id="spin" path="spin" frames="0*10,1-10" delay="0.08"/>
    <Loop id="fastspin" path="spin" frames="1-10" delay="0.08"/>
  </maggy_heartgem2>

  <maggy_heartgem3 path="collectables/Maggy/heartgem/3/" start="idle">
    <Center />
    <Loop id="idle" path="spin" frames="0" />
    <Loop id="spin" path="spin" frames="0*10,1-10" delay="0.08"/>
    <Loop id="fastspin" path="spin" frames="1-10" delay="0.08"/>
  </maggy_heartgem3>

  <heartgem4 path="collectables/Maggy/heartgem/4/" start="idle">
    <Center />
    <Loop id="idle" path="" frames="0" />
    <Loop id="spin" path="" frames="0*10,1-10" delay="0.08"/>
    <Loop id="fastspin" path="" frames="1-10" delay="0.08"/>
    <Anim id="break" path="" frames="11-32" delay="0.07"/>
  </heartgem4>

  <maggy_save path="save/Maggy/saveIcon" start="start">
    <Center />

    <Anim id="start" path="" frames="0-11" goto="idle" delay="0.04"/>
    <Loop id="idle" path="" frames="11" delay="0.08"/>
    <Anim id="end" path="" frames="11-20" delay="0.08"/>
  </maggy_save>

  <maggy_feather path="feather/Maggy/" start="hover">
    <Justify x="0.5" y="0"/>
    <Position x="0" y="-128"/>
    <Loop id="hover" path="feather" frames="0" delay="0.1"/>
    <Loop id="flutter" path="feather" frames="0-3" delay="0.1"/> 
  </maggy_feather>

  <heartGemGhost path="heartgem/Maggy/" start="hover">
    <Justify x="0.5" y="0"/>
    <Position x="0" y="-128"/>
    <Loop id="hover" path="feather" frames="0" delay="0.1"/>
    <Loop id="flutter" path="feather" frames="0-3" delay="0.1"/> 
  </heartGemGhost>

  <!-- ========================================== -->
  <!-- KIRBY UI SYSTEM                            -->
  <!-- ========================================== -->
  
  <!-- Health Display -->
  <gui_kirby_health path="maggy/kirby/" start="heart_full">
    <Origin x="6" y="6" />
    <Justification x="0.5" y="0.5" />
    
    <Anim id="heart_full" path="heart_full" delay="0.1" frames="0-10" />
    <Anim id="heart_empty" path="heart_empty" delay="0.1" frames="0" />
    <Anim id="heart_half" path="heart_half" delay="0.1" frames="0-10" />
    <Loop id="heart_beat" path="heart_full" delay="0.15" frames="0-10" />
    <Anim id="heart_damage" path="heart_empty" delay="0.05" frames="0" goto="heart_empty" />
    <Anim id="heart_heal" path="heart_full" delay="0.08" frames="0-10" goto="heart_full" />
  </gui_kirby_health>
  
</Sprites>